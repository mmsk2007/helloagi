# HelloAGI provider keys
OPENAI_API_KEY=
OPENAI_AUTH_TOKEN=
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_AUTH_TOKEN=
GOOGLE_API_KEY=
GOOGLE_AUTH_TOKEN=
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
HELLOAGI_API_KEY=
HELLOAGI_LOCAL_PRINCIPAL_ID=local:default

# Local voice channel configuration (used by `helloagi serve --voice`)
HELLOAGI_VOICE_AUDIO_BACKEND=auto
HELLOAGI_VOICE_WAKE_WORD=lana
HELLOAGI_OWNER_NAME=
HELLOAGI_VOICE_NAME=
HELLOAGI_VOICE_RATE=185
HELLOAGI_VOICE_INPUT_PROVIDER=local
HELLOAGI_VOICE_OUTPUT_PROVIDER=local
HELLOAGI_VOICE_RECOGNITION_LOCALE=en-US
HELLOAGI_VOICE_STT_BACKEND=google
HELLOAGI_VOICE_STOP_WORDS=stop,exit,quit,goodbye,sleep
HELLOAGI_VOICE_GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
HELLOAGI_VOICE_GEMINI_INPUT_MODEL=gemini-flash-latest
HELLOAGI_VOICE_GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
HELLOAGI_VOICE_GEMINI_TTS_VOICE=Kore
HELLOAGI_VOICE_GEMINI_TTS_STYLE=
HELLOAGI_VOICE_WORK_SOUND=piano
HELLOAGI_VOICE_PROGRESS_THROTTLE_SECONDS=6
HELLOAGI_VOICE_COMMAND_SILENCE_SECONDS=1.2
HELLOAGI_VOICE_COMMAND_RMS_THRESHOLD=220
HELLOAGI_VOICE_COMMAND_SAMPLE_RATE=16000
HELLOAGI_VOICE_PRINCIPAL_ID=
HELLOAGI_GOOGLE_MODEL=

# LLM backbone for agent.think(): auto | anthropic | google
# auto = first usable provider: Anthropic if ANTHROPIC_* looks like a real key, else Google when
# GOOGLE_* looks real and google-genai is installed (skips doc placeholders like sk-ant-test).
HELLOAGI_LLM_PROVIDER=auto

# Show governance metadata on Telegram replies.
# 0 = hide allow banners by default, always show escalate/deny
# 1 = always include governance header
HELLOAGI_TELEGRAM_SHOW_GOV=0

# Memory isolation policy for multi-user channels:
# compat = include legacy unscoped memories + current principal
# strict = only current principal memories
HELLOAGI_MEMORY_SCOPE=compat

# Reminder scheduler runtime controls
HELLOAGI_REMINDER_TICK_SECONDS=5
HELLOAGI_REMINDER_STUCK_SECONDS=600
HELLOAGI_REMINDER_ONESHOT_GRACE_SECONDS=300
HELLOAGI_REMINDER_TIMEZONE=UTC

# Google Gemini Embedding 2 (uses GOOGLE_API_KEY above)
# Enables semantic memory search, intent-similarity matching,
# and multimodal embedding (text, images, video, audio).
# Get your key at: https://aistudio.google.com/apikey
