# HelloAGI provider keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=
TELEGRAM_BOT_TOKEN=

# LLM backbone for agent.think(): auto | anthropic | google
# auto = Claude if ANTHROPIC_API_KEY else Gemini if GOOGLE_API_KEY + google-genai installed
HELLOAGI_LLM_PROVIDER=auto

# Show governance metadata on Telegram replies.
# 0 = hide allow banners by default, always show escalate/deny
# 1 = always include governance header
HELLOAGI_TELEGRAM_SHOW_GOV=0

# Memory isolation policy for multi-user channels:
# compat = include legacy unscoped memories + current principal
# strict = only current principal memories
HELLOAGI_MEMORY_SCOPE=compat

# Reminder scheduler runtime controls
HELLOAGI_REMINDER_TICK_SECONDS=5
HELLOAGI_REMINDER_STUCK_SECONDS=600
HELLOAGI_REMINDER_ONESHOT_GRACE_SECONDS=300
HELLOAGI_REMINDER_TIMEZONE=UTC

# Google Gemini Embedding 2 (uses GOOGLE_API_KEY above)
# Enables semantic memory search, intent-similarity matching,
# and multimodal embedding (text, images, video, audio).
# Get your key at: https://aistudio.google.com/apikey
