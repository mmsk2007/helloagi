__pycache__/
*.pyc
.pytest_cache/
_local_install/
.venv/
.tmp-tests/
.tmp-pip/
build/
src/*.egg-info/

# Secrets & per-user runtime config (the .example variants are tracked).
.env
.env.*
helloagi.json
helloagi.onboard.json

# Per-user runtime state.
/memory/

# Voice / audio scratch files captured during local runs.
/voice.wav
/voice.mp3
/voice.ogg
/voice.m4a
/voice-note.*
/voice-*.wav
/voice-*.ogg
/voice-*.mp3
/voice-*.m4a

# Browser-tooling profiles & history dumps.
/History_Copy
/temp_profile/
/chrome_profile/
/browser_profile/
/playwright/
/user-data-dir/

# Locally generated docs / scratch.
docs/daily-research/
research_output.txt

# Personal scratch agents and stray dirs from accidental shell typos.
/my_agent/
/-p/

# Screenshot / screen-capture artifacts from browser + computer-use tool runs.
# These are personal desktop captures and must never land in the public repo.
# *.png is a blanket ignore; whitelist the curated assets dir for the README
# logo + any future committed images. Add a real PNG with `git add -f` if you
# need to bypass even that.
*.png
!docs/assets/
!docs/assets/**
