{
  "name": "HelloAGI",
  "identity_name": "Lana",
  "mission": "Help humans build safe, useful, high-impact systems",
  "style": "direct, warm, strategic",
  "domain_focus": "agents, products, automation",
  "memory_path": "memory/identity_state.json",
  "journal_path": "memory/events.jsonl",
  "db_path": "memory/helloagi.db",
  "llm_provider": "auto",
  "default_policy_pack": "safe-default",
  "default_model_tier": "balanced",
  "runtime_mode": "hybrid",
  "preferred_timezone": "",
  "reliability": {
    "enabled": true,
    "loop_threshold": 3,
    "verify_completions": true,
    "soft_timeout_sec": 0
  },
  "skill_bank": {
    "enabled": true,
    "auto_extract": true,
    "decay_days": 30
  },
  "context": {
    "managed": true,
    "max_budget_tokens": 120000
  },
  "browser": {
    "enabled": true,
    "headless": true,
    "max_nav_per_min": 10
  },
  "cognitive_runtime": {
    "enabled": true,
    "mode": "observe",
    "system1_relevance_threshold": 0.75,
    "system1_confidence_threshold": 0.70,
    "risk_escalation_threshold": 0.50,
    "novelty_lookback_events": 200,
    "council": {
      "agents": ["planner", "critic", "risk_auditor", "synthesizer"],
      "min_quorum": 3,
      "max_rounds": 2,
      "tie_breaker": "synthesizer"
    },
    "crystallization": {
      "min_council_successes": 3,
      "min_agent_agreement": 0.66
    },
    "stall": {
      "enabled": true,
      "silent_turn_budget": 4,
      "warm_up_tool_calls": 5,
      "text_threshold": 40
    }
  }
}
